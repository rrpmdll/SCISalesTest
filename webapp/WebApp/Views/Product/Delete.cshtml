@model ProductViewModel
@{
    ViewData["Title"] = "Delete Product";
}

<h2 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Delete Product</h2>
<hr />

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this product?</strong> This action cannot be undone.
</div>

<div class="card shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

            <dt class="col-sm-4">Description</dt>
            <dd class="col-sm-8">@Model.Description</dd>

            <dt class="col-sm-4">Price (USD)</dt>
            <dd class="col-sm-8">@Model.Price.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</dd>

            <dt class="col-sm-4">Units in Stock</dt>
            <dd class="col-sm-8">@Model.UnitsInStock</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Confirm Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Cancel
        </a>
    </div>
</form>
