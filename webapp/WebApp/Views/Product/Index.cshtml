@model ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Products</h2>
    <div class="d-flex gap-3 align-items-center">
        <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
            <label for="currency" class="form-label mb-0 fw-bold text-nowrap">Currency:</label>
            <select name="currency" id="currency" class="form-select form-select-sm" style="width: 140px;" onchange="this.form.submit()">
                @foreach (var code in Model.SupportedCurrencies)
                {
                    <option value="@code" selected="@(Model.SelectedCurrency == code)">@code</option>
                }
            </select>
        </form>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New Product
        </a>
    </div>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No products found. Create your first product!
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 60px;">Image</th>
                    <th>Name</th>
                    <th class="text-end">USD</th>
                    <th class="text-end">@Model.SelectedCurrency</th>
                    <th class="text-center">Stock</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td>
                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                <i class="bi bi-box-seam text-secondary fs-5"></i>
                            </div>
                        </td>
                        <td>
                            <strong>@product.Name</strong>
                            <br />
                            <small class="text-muted">@(product.Description.Length > 60 ? product.Description[..60] + "..." : product.Description)</small>
                        </td>
                        <td class="text-end fw-bold text-success">
                            @product.OriginalPrice.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                        </td>
                        <td class="text-end fw-bold text-primary">
                            @product.ConvertedPrice.ToString("N2") @product.TargetCurrency
                        </td>
                        <td class="text-center">
                            <span class="badge @(product.UnitsInStock > 0 ? "bg-success" : "bg-danger")">
                                @product.UnitsInStock
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
