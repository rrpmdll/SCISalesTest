@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Error</h1>
    <h2 class="text-danger">An error occurred while processing your request.</h2>

    @if (Model?.ShowRequestId ?? false)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    @if (!string.IsNullOrEmpty(Model?.Message))
    {
        <p class="text-muted">@Model.Message</p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
        <i class="bi bi-house"></i> Back to Home
    </a>
</div>
